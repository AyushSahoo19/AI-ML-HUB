---
import '../styles/global.css';

export interface Props {
	title?: string;
}

const { title = 'Neo-Brutalist Site' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
	</head>
	<body>
		<header class="neo-border neo-shadow bg-violet" style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1.5rem; margin: 1rem; margin-bottom: 2rem;">
			<div style="font-size: 1.25rem; font-weight: 900; text-transform: uppercase;">
				<a href="/" style="text-decoration: none; color: inherit;">AI/ML Hub</a>
			</div>
			<nav style="display: flex; gap: 0.75rem; font-size: 0.85rem; font-weight: bold; flex-wrap: wrap; justify-content: flex-end;">
				<a href="/" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem;" class="neo-border bg-yellow neo-hover-raise">Home</a>
				<a href="/syllabus" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #a8d5ff;" class="neo-border neo-hover-raise">Syllabus</a>
				<a href="/guidance" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #fff;" class="neo-border neo-hover-raise">Guidance</a>
				<a href="/lectures" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem;" class="neo-border bg-green neo-hover-raise">Notes</a>
				<a href="/projects" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #e3a8ff;" class="neo-border neo-hover-raise">Projects</a>
				<a href="/experiments" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #fca5a5;" class="neo-border neo-hover-raise">Experiments</a>
				<a href="/github" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #e2e8f0;" class="neo-border neo-hover-raise">GitHub</a>
			</nav>
		</header>
		<main style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
			<slot />
		</main>

		<footer class="neo-border bg-white" style="max-width: 1200px; margin: 4rem auto 2rem; padding: 2rem; border-width: 3px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
			<div>
				<h3 style="font-size: 1.25rem; font-weight: 900; text-transform: uppercase; margin: 0;">AI/ML IIT Mandi Hub</h3>
				<p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; margin-top: 0.25rem;">Open-Source Learning Ecosystem</p>
			</div>
			<div style="display: flex; gap: 1.5rem; font-size: 0.9rem; font-weight: bold;">
				<a href="/lectures" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Lecture Vault</a>
				<a href="/projects" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Projects</a>
				<a href="/github" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">GitHub Code Hub</a>
				<a href="/guidance" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Guidance</a>
			</div>
		</footer>
	</body>
</html>
