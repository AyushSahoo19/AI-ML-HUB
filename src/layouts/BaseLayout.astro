---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

export interface Props {
	title?: string;
}

const { title = 'Neo-Brutalist Site' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0, user-scalable=yes" />
		<title>{title}</title>
		
		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/icons/icon-192.png" />
		
		<!-- PWA Meta Tags -->
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#a8d5ff" />
		
		<!-- iOS Web App Capability -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="AI/ML Hub" />
		<link rel="apple-touch-icon" href="/icons/icon-192.png" />
		
		<!-- Windows Tile Metadata -->
		<meta name="msapplication-TileImage" content="/icons/icon-192.png" />
		<meta name="msapplication-TileColor" content="#a8d5ff" />
	</head>
	<body>
		<header class="neo-border neo-shadow bg-violet site-header">
			<div class="header-logo">
				<a href="/" style="text-decoration: none; color: inherit;">AI/ML Hub</a>
			</div>
			<nav class="nav-container">
				<a href="/" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem;" class="neo-border bg-yellow neo-hover-raise">Home</a>
				<a href="/syllabus" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #a8d5ff;" class="neo-border neo-hover-raise">Syllabus</a>
				<a href="/guidance" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #fff;" class="neo-border neo-hover-raise">Guidance</a>
				<a href="/lectures" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem;" class="neo-border bg-green neo-hover-raise">Notes</a>
				<a href="/projects" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #e3a8ff;" class="neo-border neo-hover-raise">Projects</a>
				<a href="/experiments" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #fca5a5;" class="neo-border neo-hover-raise">Experiments</a>
				<a href="/github" style="text-decoration: none; color: inherit; padding: 0.25rem 0.75rem; background-color: #e2e8f0;" class="neo-border neo-hover-raise">GitHub</a>
			</nav>
		</header>
		<main class="main-content">
			<slot />
		</main>

		<footer class="neo-border bg-white site-footer">
			<div class="footer-title-block">
				<h3 style="font-size: 1.25rem; font-weight: 900; text-transform: uppercase; margin: 0;">AI/ML IIT Mandi Hub</h3>
				<p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; margin-top: 0.25rem;">Open-Source Learning Ecosystem</p>
			</div>
			<div class="footer-nav-block">
				<a href="/lectures" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Lecture Vault</a>
				<a href="/projects" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Projects</a>
				<a href="/github" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">GitHub Code Hub</a>
				<a href="/guidance" style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent;" onmouseover="this.style.borderBottom='2px solid #000'" onmouseout="this.style.borderBottom='2px solid transparent'">Guidance</a>
			</div>
		</footer>

		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then((reg) => {
							console.log('Service Worker registered scope:', reg.scope);
						})
						.catch((err) => {
							console.error('Service Worker registration failed:', err);
						});
				});
			}
		</script>

		<style>
			.site-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.75rem 1.5rem;
				margin: 1rem;
				margin-bottom: 2rem;
				border-width: 3px;
			}
			.header-logo {
				font-size: 1.25rem;
				font-weight: 900;
				text-transform: uppercase;
			}
			.nav-container {
				display: flex;
				gap: 0.75rem;
				font-size: 0.85rem;
				font-weight: bold;
				flex-wrap: wrap;
				justify-content: flex-end;
			}
			.main-content {
				max-width: 1200px;
				margin: 0 auto;
				padding: 2rem;
			}
			.site-footer {
				max-width: 1200px;
				margin: 4rem auto 2rem;
				padding: 2rem;
				border-width: 3px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: 1rem;
			}
			.footer-title-block {
				text-align: left;
			}
			.footer-nav-block {
				display: flex;
				gap: 1.5rem;
				font-size: 0.9rem;
				font-weight: bold;
				flex-wrap: wrap;
			}

			@media (max-width: 768px) {
				.site-header {
					flex-direction: column;
					gap: 1rem;
					padding: 1rem;
					margin: 0.5rem;
					margin-bottom: 1rem;
					text-align: center;
				}
				.nav-container {
					justify-content: center;
					gap: 0.5rem;
					width: 100%;
				}
				.main-content {
					padding: 1rem 0.75rem;
				}
				.site-footer {
					flex-direction: column;
					text-align: center;
					padding: 1.5rem;
					margin: 2rem 0.5rem 1rem;
					gap: 1.5rem;
				}
				.footer-title-block {
					text-align: center;
				}
				.footer-nav-block {
					justify-content: center;
					gap: 1rem;
				}
			}
		</style>
		<Analytics />
	</body>
</html>
