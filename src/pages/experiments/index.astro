---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NeoCard from '../../components/NeoCard.astro';
---

<BaseLayout title="Live Experiments - AI/ML IIT Mandi">
  <div style="max-width: 1000px; margin: 0 auto;">
    
    <!-- Header banner -->
    <section class="neo-border neo-shadow bg-yellow" style="padding: 2.5rem 2rem; margin-bottom: 3rem; background-color: #fca5a5; color: #000;">
      <h1 style="font-size: 2.5rem; font-weight: 900; text-transform: uppercase; margin-bottom: 0.5rem;">Live Experiments</h1>
      <p style="font-size: 1.1rem; font-weight: bold; margin: 0; color: #1f2937;">
        Interactive client-side models and simulators designed to render abstract AI algorithms and mathematical manifolds visible.
      </p>
    </section>

    <!-- Experiments Directory Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
      
      <!-- Experiment 1: Gradient Descent -->
      <div class="neo-border neo-shadow" style="background-color: #fff; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="padding: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <span style="font-size: 1.75rem;">📈</span>
            <span style="font-size: 0.7rem; font-weight: 900; border: 2px solid #000; padding: 0.15rem 0.5rem; background: #bbf7d0; text-transform: uppercase;">Active</span>
          </div>
          <h2 style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000;">
            Gradient Descent Convergence
          </h2>
          <p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; line-height: 1.5; margin: 0 0 1.5rem 0;">
            A real-time interactive HTML5 canvas simulator. Customize variables like learning rate, initial point, and loss functions (Quadratic vs double-well landscape) and watch weights converge down the gradient.
          </p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#HTML5-Canvas</span>
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Math-Derivation</span>
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Interactive</span>
          </div>
        </div>
        <div style="border-top: 3px solid #000; padding: 1rem 1.5rem; background: #fafafa; text-align: right;">
          <a href="/experiments/gradient-descent" class="neo-border" style="background-color: #fde047; text-decoration: none; color: #000; padding: 0.5rem 1.25rem; font-size: 0.85rem; font-weight: 900; box-shadow: 2px 2px 0px #000; display: inline-block;" onmouseover="this.style.transform='translate(-1px,-1px)'; this.style.boxShadow='3px 3px 0px #000';" onmouseout="this.style.transform='none'; this.style.boxShadow='2px 2px 0px #000';">
            Run Simulator &rarr;
          </a>
        </div>
      </div>

      <!-- Experiment 2: Neural Boundary (Upcoming) -->
      <div class="neo-border neo-shadow" style="background-color: #fff; opacity: 0.75; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="padding: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <span style="font-size: 1.75rem;">🕸️</span>
            <span style="font-size: 0.7rem; font-weight: 900; border: 2px solid #000; padding: 0.15rem 0.5rem; background: #e5e7eb; text-transform: uppercase;">Upcoming</span>
          </div>
          <h2 style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000;">
            Neural Network Decision Boundary
          </h2>
          <p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; line-height: 1.5; margin: 0 0 1.5rem 0;">
            An interactive multi-layer perceptron training directly in your browser. Choose data distribution shapes (circles, spirals, XOR) and configure hidden neurons to witness spatial boundary warping.
          </p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Deep-Learning</span>
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Neural-Nets</span>
          </div>
        </div>
        <div style="border-top: 3px solid #000; padding: 1rem 1.5rem; background: #fafafa; display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 0.75rem; font-weight: bold; color: #6b7280;">Development: 40%</span>
          <button disabled class="neo-border" style="background-color: #e5e7eb; color: #9ca3af; padding: 0.5rem 1.25rem; font-size: 0.85rem; font-weight: 900; cursor: not-allowed; border-color: #9ca3af;">
            Locked
          </button>
        </div>
      </div>

      <!-- Experiment 3: K-Means Animator (Upcoming) -->
      <div class="neo-border neo-shadow" style="background-color: #fff; opacity: 0.75; display: flex; flex-direction: column; justify-content: space-between;">
        <div style="padding: 1.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <span style="font-size: 1.75rem;">🧬</span>
            <span style="font-size: 0.7rem; font-weight: 900; border: 2px solid #000; padding: 0.15rem 0.5rem; background: #e5e7eb; text-transform: uppercase;">Upcoming</span>
          </div>
          <h2 style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000;">
            K-Means Clustering Animator
          </h2>
          <p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; line-height: 1.5; margin: 0 0 1.5rem 0;">
            See clustering centroids shift dynamically based on standard expectation-maximisation updating. Add cluster coordinates manually or generate random point clouds to watch boundaries lock in.
          </p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Unsupervised</span>
            <span style="font-size: 0.75rem; font-weight: bold; background-color: #f3f4f6; border: 1px solid #000; padding: 0.2rem 0.5rem;">#Clustering</span>
          </div>
        </div>
        <div style="border-top: 3px solid #000; padding: 1rem 1.5rem; background: #fafafa; display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 0.75rem; font-weight: bold; color: #6b7280;">Development: 10%</span>
          <button disabled class="neo-border" style="background-color: #e5e7eb; color: #9ca3af; padding: 0.5rem 1.25rem; font-size: 0.85rem; font-weight: 900; cursor: not-allowed; border-color: #9ca3af;">
            Locked
          </button>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
