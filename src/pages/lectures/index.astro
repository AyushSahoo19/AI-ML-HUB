---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const lectures = await getCollection('lectures');

// Curated COURSE_STRUCTURE
const COURSE_STRUCTURE = [
  {
    id: "intro-ai-ml",
    title: "Introduction to AI and Machine Learning",
    description: "Explore the core definitions of AI vs ML, feature extraction, curse of dimensionality, classification algorithms, gradient descent, and how lines act as boundaries in parametric and data spaces.",
    color: "#f5d0fe", // Soft brutalist lilac/purple
    filterCategory: "ml-dl"
  },
  {
    id: "python-foundations",
    title: "Python Foundations",
    description: "Learn Python fundamentals including data types, operators, strings, loops, conditionals, functions, core data structures, and file handling to build a strong programming base",
    color: "#a8d5ff", // Soft blue
    filterCategory: "python-dsa"
  },
  {
    id: "data-structures-i",
    title: "Data Structures I",
    description: "Understand Big-O notation, time and space complexity, arrays, linked lists, and binary search to develop efficient problem-solving skills",
    color: "#bbf7d0", // Soft green
    filterCategory: "python-dsa"
  },
  {
    id: "data-structures-ii",
    title: "Data Structures II",
    description: "Work with stacks, queues, and sorting algorithms such as bubble, insertion, merge, and quicksort while learning to evaluate efficiency and trade-offs across approaches",
    color: "#ffd6e8", // Soft pink
    filterCategory: "python-dsa"
  },
  {
    id: "database-engineering",
    title: "Database Engineering and Schema Design",
    description: "Build foundations in relational databases and SQL, learn schema design and normalization, map entities into relational models, and optimize data retrieval using joins and indexing",
    color: "#fed7aa", // Soft orange
    filterCategory: "databases"
  },
  {
    id: "classical-ml",
    title: "Fundamentals of Classical Machine Learning",
    description: "Explore supervised and unsupervised learning, build models such as linear regression and random forests, evaluate them with the right metrics, and learn clustering and PCA",
    color: "#fef08a", // Soft yellow
    filterCategory: "ml-dl"
  },
  {
    id: "deep-learning",
    title: "Fundamentals of Deep Learning",
    description: "Understand neural networks, multi-layer perceptrons, CNNs, LSTMs, and transformer architectures as the foundation for modern AI systems",
    color: "#e9d5ff", // Soft purple
    filterCategory: "ml-dl"
  },
  {
    id: "generative-ai",
    title: "Generative AI and Foundation Models",
    description: "Learn how modern foundation models work, including BERT, GPT, LLaMA, and CLIP; explore multimodal pretraining, fine-tuning methods, prompt design, context management, and RAG pipelines",
    color: "#cbd5e1", // Soft slate/grey
    filterCategory: "genai"
  },
  {
    id: "ai-assisted-dev",
    title: "AI-Assisted Software Development",
    description: "Apply AI to software development workflows through code generation, debugging, testing, documentation, codebase understanding, and agentic coding environments",
    color: "#fda4af", // Soft rose
    filterCategory: "genai"
  },
  {
    id: "frontend-masterclass",
    title: "Masterclass Series A: Front End Development",
    description: "Cover web fundamentals, HTML, CSS, responsive layouts, JavaScript, APIs, asynchronous programming, React, state management, frontend-backend integration, and a full-stack frontend project",
    color: "#99f6e4", // Soft teal
    filterCategory: "masterclasses"
  },
  {
    id: "backend-masterclass",
    title: "Masterclass Series B: Back End Development",
    description: "Cover backend fundamentals, servers, APIs, CRUD operations, databases, frontend-backend integration, authentication, application structuring, error handling, and a full-stack backend project",
    color: "#bfdbfe", // Soft sky blue
    filterCategory: "masterclasses"
  }
];

// Map lectures to their corresponding course module structure
const lecturesByModule = COURSE_STRUCTURE.reduce((acc, mod) => {
  acc[mod.title] = [];
  return acc;
}, {} as Record<string, typeof lectures>);

lectures.forEach(lecture => {
  const modTitle = lecture.data.module || 'Python Foundations';
  // Try to find the closest match or default to Python Foundations
  const matchedMod = COURSE_STRUCTURE.find(m => m.title.toLowerCase() === modTitle.toLowerCase() || m.title.toLowerCase().startsWith(modTitle.toLowerCase()));
  if (matchedMod) {
    lecturesByModule[matchedMod.title].push(lecture);
  } else {
    // Fallback logic
    if (lecturesByModule['Python Foundations']) {
      lecturesByModule['Python Foundations'].push(lecture);
    }
  }
});

// Sort lectures by day inside each module
Object.keys(lecturesByModule).forEach(key => {
  lecturesByModule[key].sort((a, b) => a.data.day - b.data.day);
});
---

<BaseLayout title="Lecture Vault - AI/ML IIT Mandi">
  <div style="max-width: 1100px; margin: 0 auto; padding: 0 1rem;">
    
    <!-- Header banner -->
    <section class="neo-border neo-shadow" style="padding: 3rem 2rem; margin-top: 2rem; margin-bottom: 3rem; background-color: #bbf7d0; box-shadow: 6px 6px 0px #000;">
      <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem;">
        <div>
          <h1 style="font-size: 3rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000; letter-spacing: -1px; line-height: 1;">Lecture Vault</h1>
          <p style="font-size: 1.2rem; font-weight: 800; margin: 0; color: #1f2937;">
            Mastering Artificial Intelligence, Machine Learning, and Modern Software Engineering.
          </p>
        </div>
        <div class="neo-border bg-white" style="padding: 0.75rem 1.5rem; font-weight: 900; font-size: 1rem; box-shadow: 4px 4px 0px #000; text-transform: uppercase; letter-spacing: 0.5px;">
          📚 {lectures.length} Lectures Total
        </div>
      </div>
    </section>

    <!-- Search & Filter Controls -->
    <div class="neo-border" style="padding: 1.5rem; background-color: #fff; margin-bottom: 2.5rem; box-shadow: 6px 6px 0px #000; display: flex; gap: 1.5rem; flex-direction: column;">
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; width: 100%;">
        <div style="flex-grow: 1; min-width: 280px;">
          <label for="search-input" style="display: block; font-weight: 900; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 0.5rem; letter-spacing: 0.5px;">🔍 Instant Search Vault</label>
          <input 
            id="search-input" 
            type="text" 
            placeholder="Search by day, lecture title, specific topic tags (e.g. PCA, React, Big-O)..." 
            style="width: 100%; padding: 1rem; border: 3px solid #000; font-family: inherit; font-weight: bold; box-sizing: border-box; font-size: 1rem; outline: none; border-radius: 0; box-shadow: 3px 3px 0px #000; transition: transform 0.1s ease, box-shadow 0.1s ease;"
          />
        </div>
      </div>
      <div>
        <label style="display: block; font-weight: 900; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 0.5rem; letter-spacing: 0.5px;">🎯 Filter course curriculum</label>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <button class="filter-btn active" data-filter="all" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #fff; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">All Modules</button>
          <button class="filter-btn" data-filter="python-dsa" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #a8d5ff; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">Python & DSA</button>
          <button class="filter-btn" data-filter="databases" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #fed7aa; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">Databases</button>
          <button class="filter-btn" data-filter="ml-dl" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #e9d5ff; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">ML & Deep Learning</button>
          <button class="filter-btn" data-filter="genai" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #fda4af; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">Generative AI</button>
          <button class="filter-btn" data-filter="masterclasses" style="padding: 0.6rem 1.2rem; font-weight: 900; border: 3px solid #000; background: #99f6e4; cursor: pointer; text-transform: uppercase; box-shadow: 3px 3px 0px #000; transition: all 0.15s ease;">Masterclasses</button>
        </div>
      </div>
    </div>

    <!-- Course Modules Cards -->
    <div id="course-vault" style="display: flex; flex-direction: column; gap: 2.5rem; margin-bottom: 5rem;">
      {COURSE_STRUCTURE.map((module, index) => {
        const moduleLectures = lecturesByModule[module.title] || [];
        const indexStr = String(index).padStart(2, '0');

        return (
          <div class="course-module-card neo-border" data-category={module.filterCategory} data-title={module.title.toLowerCase()} data-description={module.description.toLowerCase()} style={`background-color: ${module.color}; box-shadow: 8px 8px 0px #000; transition: all 0.2s ease; display: flex; flex-direction: column; overflow: hidden;`}>
            
            <!-- Module Top Branding & Info -->
            <div style="padding: 2rem 2rem 1.5rem 2rem; display: flex; flex-direction: column; gap: 0.75rem;">
              <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem;">
                <span class="neo-border" style="background-color: #000; color: #fff; padding: 0.25rem 0.75rem; font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px;">
                  MODULE {indexStr}
                </span>
                <span class="neo-border bg-white" style="padding: 0.25rem 0.75rem; font-size: 0.8rem; font-weight: 900; text-transform: uppercase;">
                  📚 {moduleLectures.length} {moduleLectures.length === 1 ? 'Lecture' : 'Lectures'}
                </span>
              </div>
              <h2 style="font-size: 1.8rem; font-weight: 900; margin: 0; line-height: 1.2; text-transform: uppercase; color: #000; letter-spacing: -0.5px;">
                {module.title}
              </h2>
              <p style="font-size: 1rem; font-weight: bold; margin: 0; color: #2d3748; line-height: 1.5; max-width: 850px;">
                {module.description}
              </p>
            </div>

            <!-- Divider Line -->
            <div style="border-top: 3px solid #000; width: 100%;"></div>

            <!-- Day-Wise Lectures Segment -->
            <div style="background-color: #fff; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; flex-grow: 1;">
              <h3 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; margin: 0; color: #000; letter-spacing: 0.5px; display: flex; align-items: center; gap: 0.5rem;">
                <span>📅 Day-Wise Lectures</span>
              </h3>
              
              {moduleLectures.length > 0 ? (
                <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                  {moduleLectures.map((lecture) => {
                    const topicsList = lecture.data.topics || [];
                    
                    return (
                      <div class="day-lecture-row neo-border" data-lecture-title={lecture.data.title.toLowerCase()} data-topics={topicsList.join(" ").toLowerCase()} data-day={lecture.data.day} style="padding: 1.25rem; background-color: #fafafa; box-shadow: 4px 4px 0px #000; transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; gap: 1rem;">
                        
                        <!-- Lecture Meta Header -->
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.75rem;">
                          <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                            <span class="neo-border" style="background-color: #fef08a; color: #000; font-weight: 900; font-size: 0.8rem; padding: 0.2rem 0.6rem; text-transform: uppercase; letter-spacing: 0.5px;">
                              Day {lecture.data.day}
                            </span>
                            <span style="font-size: 0.8rem; font-weight: bold; color: #6b7280;">
                              📅 {lecture.data.date}
                            </span>
                          </div>
                        </div>

                        <!-- Lecture Title -->
                        <h4 style="font-size: 1.25rem; font-weight: 900; margin: 0; color: #000; line-height: 1.3;">
                          <a href={`/lectures/${lecture.id}`} style="color: inherit; text-decoration: none; border-bottom: 2px solid transparent; transition: border-bottom-color 0.15s ease;" onmouseover="this.style.borderBottomColor='#000'" onmouseout="this.style.borderBottomColor='transparent'">
                            {lecture.data.title}
                          </a>
                        </h4>

                        <!-- Topics Tags -->
                        {topicsList.length > 0 && (
                          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.25rem;">
                            {topicsList.map((topic: string) => (
                              <span class="topic-tag neo-border" style="font-size: 0.75rem; font-weight: 800; background-color: #f3f4f6; color: #374151; padding: 0.2rem 0.5rem; border-width: 1.5px; border-radius: 4px;">
                                #{topic}
                              </span>
                            ))}
                          </div>
                        )}

                        <!-- Action Buttons -->
                        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; border-top: 1.5px dashed #e5e7eb; padding-top: 1rem;">
                          
                          {lecture.data.pdfUrl && (
                            <a href={lecture.data.pdfUrl} target="_blank" rel="noopener noreferrer" class="action-btn neo-border bg-rose" style="background-color: #fecaca; text-decoration: none; color: #000; font-weight: 900; font-size: 0.8rem; padding: 0.4rem 0.8rem; display: inline-flex; align-items: center; gap: 0.4rem; border-width: 2px; box-shadow: 2px 2px 0px #000;">
                              <span>📄 PDF Notes</span>
                            </a>
                          )}

                          {lecture.data.material && (
                            <a href={lecture.data.material} target="_blank" rel="noopener noreferrer" class="action-btn neo-border bg-teal" style="background-color: #ccfbf1; text-decoration: none; color: #000; font-weight: 900; font-size: 0.8rem; padding: 0.4rem 0.8rem; display: inline-flex; align-items: center; gap: 0.4rem; border-width: 2px; box-shadow: 2px 2px 0px #000;">
                              <span>💻 Code & Material</span>
                            </a>
                          )}

                          <a href={`/lectures/${lecture.id}`} class="action-btn neo-border bg-yellow" style="background-color: #fef08a; text-decoration: none; color: #000; font-weight: 900; font-size: 0.8rem; padding: 0.4rem 0.8rem; display: inline-flex; align-items: center; gap: 0.4rem; border-width: 2px; box-shadow: 2px 2px 0px #000; margin-left: auto;">
                            <span>Read Lecture Notes ➔</span>
                          </a>

                        </div>
                      </div>
                    );
                  })}
                </div>
              ) : (
                <div class="neo-border" style="border-style: dashed; padding: 1.5rem; text-align: center; background-color: #f9fafb;">
                  <span style="font-size: 1.5rem;">🚧</span>
                  <p style="font-weight: bold; color: #6b7280; margin: 0.5rem 0 0 0; font-size: 0.9rem;">
                    Lectures are currently being cataloged. Check back soon!
                  </p>
                </div>
              )}
            </div>

          </div>
        );
      })}
    </div>

    <!-- No results banner -->
    <div id="no-results" style="display: none; text-align: center; padding: 4rem 2rem; background: #fff; box-shadow: 6px 6px 0px #000;" class="neo-border">
      <div style="font-size: 3rem; margin-bottom: 1rem;">🔍❌</div>
      <h3 style="font-size: 1.8rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000;">No Matches Found</h3>
      <p style="font-size: 1rem; font-weight: bold; color: #4b5563; margin: 0;">
        We couldn't find any lectures, topics, or modules matching your search. Try another keyword!
      </p>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const searchInput = document.getElementById('search-input');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const courseModules = document.querySelectorAll('.course-module-card');
  const noResults = document.getElementById('no-results');

  let activeFilter = 'all';
  let searchQuery = '';

  function filterVault() {
    let visibleModulesCount = 0;

    courseModules.forEach(moduleCard => {
      const category = moduleCard.getAttribute('data-category');
      const moduleTitle = moduleCard.getAttribute('data-title');
      const moduleDesc = moduleCard.getAttribute('data-description');
      
      const lectureRows = moduleCard.querySelectorAll('.day-lecture-row');
      let visibleLecturesInModule = 0;

      lectureRows.forEach(row => {
        const lectureTitle = row.getAttribute('data-lecture-title');
        const topics = row.getAttribute('data-topics');
        const day = row.getAttribute('data-day');

        // Check if search matches lecture title, topics or day
        const matchesSearch = 
          searchQuery === '' ||
          lectureTitle.includes(searchQuery) ||
          topics.includes(searchQuery) ||
          day === searchQuery ||
          ("day " + day).includes(searchQuery) ||
          moduleTitle.includes(searchQuery) ||
          moduleDesc.includes(searchQuery);

        // Check if category matches active filter button
        const matchesCategory = activeFilter === 'all' || category === activeFilter;

        if (matchesSearch && matchesCategory) {
          row.style.display = 'flex';
          visibleLecturesInModule++;
        } else {
          row.style.display = 'none';
        }
      });

      // A module card is shown if:
      // 1. It matches the category filter AND
      // 2. Either there is at least one visible lecture inside it OR the search query matches the module title/description (even if it has no lectures yet, or if it is the only matching container)
      const matchesCategoryFilter = activeFilter === 'all' || category === activeFilter;
      const hasVisibleLectures = visibleLecturesInModule > 0;
      const moduleItselfMatchesSearch = 
        searchQuery === '' || 
        moduleTitle.includes(searchQuery) || 
        moduleDesc.includes(searchQuery);

      if (matchesCategoryFilter && (hasVisibleLectures || (moduleItselfMatchesSearch && lectureRows.length === 0))) {
        moduleCard.style.display = 'flex';
        visibleModulesCount++;
        
        // Show/hide empty state if no lectures are visible but the module is kept visible
        const emptyState = moduleCard.querySelector('.day-lecture-row') === null ? moduleCard.querySelector('div[style*="dashed"]') : null;
        if (emptyState) {
          emptyState.style.display = 'block';
        }
      } else {
        moduleCard.style.display = 'none';
      }
    });

    if (visibleModulesCount === 0) {
      noResults.style.display = 'block';
    } else {
      noResults.style.display = 'none';
    }
  }

  // Bind search event
  searchInput?.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase().trim();
    filterVault();
  });

  // Bind filter buttons
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active');
        b.style.backgroundColor = '';
        b.style.color = '';
        b.style.transform = '';
        b.style.boxShadow = '';
      });
      
      btn.classList.add('active');
      activeFilter = btn.getAttribute('data-filter') || 'all';
      
      // Highlight selected button with brutalist active styling
      btn.style.backgroundColor = '#000';
      btn.style.color = '#fff';
      btn.style.boxShadow = '1px 1px 0px #000';
      btn.style.transform = 'translate(2px, 2px)';
      
      filterVault();
    });
  });

  // Setup initial active button styling
  const initialActive = document.querySelector('.filter-btn.active');
  if (initialActive) {
    initialActive.style.backgroundColor = '#000';
    initialActive.style.color = '#fff';
    initialActive.style.boxShadow = '1px 1px 0px #000';
    initialActive.style.transform = 'translate(2px, 2px)';
  }
</script>

<style>
  .filter-btn:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0px #000 !important;
  }
  
  .day-lecture-row:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #000 !important;
  }

  /* Micro animations on action buttons */
  .action-btn {
    transition: transform 0.1s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.1s ease;
  }
  .action-btn:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0px #000 !important;
  }
  .action-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #000 !important;
  }
</style>
