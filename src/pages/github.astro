        prs.forEach(pr => {
          const div = document.createElement('div');
          div.className = "neo-border";
          div.style.padding = "1.25rem";
          div.style.backgroundColor = "#fff";
          div.style.borderWidth = "2.5px";
          div.style.display = "flex";
          div.style.justifyContent = "space-between";
          div.style.alignItems = "center";
          div.style.gap = "1rem";
          div.style.flexWrap = "wrap";
          
          div.innerHTML = `
            <div>
              <h3 style="font-size: 1.1rem; font-weight: bold; margin: 0;">
                ⌥ #${pr.id} ${pr.title}
              </h3>
              <p style="font-size: 0.85rem; font-weight: bold; color: #4b5563; margin: 0.25rem 0;">
                ${pr.desc}
              </p>
              <div style="font-size: 0.75rem; font-weight: bold; color: #9ca3af; display: flex; gap: 1rem; margin-top: 0.5rem;">
                <span>branch: \`${pr.branch}\` &rarr; \`main\`</span>
                <span>Created ${pr.time} by 👤 ${pr.author}</span>
              </div>
            </div>
            <div>
              <span style="font-size: 0.75rem; font-weight: 900; border: 2px solid #22c55e; color: #22c55e; background-color: #f0fdf4; padding: 0.25rem 0.75rem; text-transform: uppercase;">${pr.status}</span>
            </div>
          `;
          
          prsContainer.appendChild(div);
        });
      }
    }
    
    // Populate Actions
    const actionsContainer = document.getElementById('dashboard-actions-list');
    if (actionsContainer) {
      actionsContainer.innerHTML = "";
      const actions = repoActions[repoName] || [];
      
      if (actions.length === 0) {
        actionsContainer.innerHTML = `<div style="text-align: center; font-weight: bold; color: #6b7280; padding: 1.5rem;">No action history.</div>`;
      } else {
        actions.forEach(action => {
          const div = document.createElement('div');
          div.style.display = "flex";
          div.style.justifyContent = "space-between";
          div.style.alignItems = "center";
          div.style.padding = "1rem";
          div.style.backgroundColor = "#fafafa";
          div.style.border = "2px solid #000";
          div.style.flexWrap = "wrap";
          div.style.gap = "1rem";
          
          div.innerHTML = `
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <span style="font-size: 1.5rem; color: #22c55e;">✅</span>
              <div>
                <h3 style="font-size: 0.95rem; font-weight: bold; margin: 0;">${action.name}</h3>
                <p style="font-size: 0.75rem; font-weight: bold; color: #4b5563; margin: 0.1rem 0;">Commit \`${action.commit}\` - ${action.desc}</p>
              </div>
            </div>
            <div style="text-align: right; font-size: 0.75rem; font-weight: bold; color: #4b5563;">
              <div>Workflow: \`${action.file}\`</div>
              <div>Success in ${action.duration} &bull; ${action.time}</div>
            </div>
          `;
          
          actionsContainer.appendChild(div);
        });
      }
    }
    
    // Populate Languages breakdown bar & labels
    const langBar = document.getElementById('dashboard-lang-bar');
    const langLabels = document.getElementById('dashboard-lang-labels');
    if (langBar && langLabels) {
      langBar.innerHTML = "";
      langLabels.innerHTML = "";
      
      const langs = meta.languages || [];
      langs.forEach(lang => {
        // Bar fraction
        const block = document.createElement('div');
        block.style.width = lang.percentage;
        block.style.backgroundColor = lang.color;
        block.title = `${lang.name}: ${lang.percentage}`;
        langBar.appendChild(block);
        
        // Label item
        const label = document.createElement('div');
        label.style.display = "flex";
        label.style.alignItems = "center";
        label.style.justifyContent = "space-between";
        label.innerHTML = `
          <span><span style="display:inline-block; width:10px; height:10px; border-radius:50%; background:${lang.color}; border:1px solid #000; margin-right:4px;"></span> ${lang.name}</span>
          <span>${lang.percentage}</span>
        `;
        langLabels.appendChild(label);
      });
    }
    
    // Populate Contributors list
    const contribContainer = document.getElementById('dashboard-contributors-list');
    if (contribContainer) {
      contribContainer.innerHTML = "";
      const contributors = meta.contributors || [];
      contributors.forEach(c => {
        const div = document.createElement('div');
        div.style.display = "flex";
        div.style.alignItems = "center";
        div.style.gap = "0.5rem";
        div.innerHTML = `
          <span style="font-size: 1.25rem;">${c.icon}</span>
          <div>
            <div style="color: #0969da;">${c.name}</div>
            <div style="font-size: 0.7rem; color: #4b5563;">${c.role}</div>
          </div>
        `;
        contribContainer.appendChild(div);
      });
    }
    
    // Reset repository navigation tabs to 'Code' as default
    document.querySelectorAll('.repo-tab-btn').forEach(btn => {
      btn.classList.remove('active');
      btn.style.backgroundColor = '#fff';
    });
    
    const codeTabBtn = document.querySelector('.repo-tab-btn[data-tab="code"]');
    if (codeTabBtn) {
      codeTabBtn.classList.add('active');
      codeTabBtn.style.backgroundColor = '#fde047';
    }
    
    document.querySelectorAll('.repo-tab-content-panel').forEach(p => p.classList.remove('active-panel'));
    document.getElementById('repo-tab-code-view')?.classList.add('active-panel');
    
    // Restore sidebar layout
    const rightSidebar = document.querySelector('.dashboard-right-sidebar');
    const mainContent = document.getElementById('dashboard-main-content');
    if (rightSidebar) rightSidebar.style.display = 'block';
    if (mainContent) mainContent.style.gridTemplateColumns = '';
  };

  // Close Repository detail dashboard SPA and return back to profile overview
  window.closeRepositoryDashboard = function() {
    // Hide dashboard
    const dashboard = document.getElementById('github-repo-dashboard');
    if (dashboard) dashboard.style.display = 'none';
    
    // Restore standard profile panels
    const ghSidebar = document.querySelector('.gh-sidebar');
    const ghTabsNav = document.querySelector('.gh-tabs-nav');
    const ghContentWrapper = document.querySelector('.gh-content-wrapper');
    const ghGrid = document.getElementById('github-grid');
    
    if (ghSidebar) ghSidebar.style.display = 'block';
    if (ghTabsNav) ghTabsNav.style.display = 'flex';
    if (ghContentWrapper) ghContentWrapper.style.display = 'block';
    if (ghGrid) {
      ghGrid.style.display = ''; // Restore dual column grid
    }
  };

  // Bind back button
  document.getElementById('dashboard-back-btn')?.addEventListener('click', () => {
    closeRepositoryDashboard();
  });

  // Repository Tab Buttons Click logic
  const repoTabBtns = document.querySelectorAll('.repo-tab-btn');
  const repoPanels = document.querySelectorAll('.repo-tab-content-panel');
  const repoMainLayout = document.getElementById('dashboard-main-content');

  repoTabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      repoTabBtns.forEach(b => {
        b.classList.remove('active');
        b.style.backgroundColor = '#fff';
      });
      repoPanels.forEach(p => p.classList.remove('active-panel'));

      btn.classList.add('active');
      btn.style.backgroundColor = '#fde047';
      
      const targetPanel = document.getElementById(`repo-tab-${btn.getAttribute('data-tab')}-view`);
      if (targetPanel) {
        targetPanel.classList.add('active-panel');
      }

      // Toggle right sidebar visibility on tabs other than Code tab
      const isCode = btn.getAttribute('data-tab') === 'code';
      const side = document.querySelector('.dashboard-right-sidebar');
      if (isCode) {
        if (repoMainLayout) repoMainLayout.style.gridTemplateColumns = '';
        if (side) side.style.display = 'block';
      } else {
        if (repoMainLayout) repoMainLayout.style.gridTemplateColumns = '1fr';
        if (side) side.style.display = 'none';
      }
    });
  });

  // Repository Branch Selector toggling
  const dashBranchBtn = document.getElementById('dashboard-branch-btn');
  const dashBranchDropdown = document.getElementById('dashboard-branch-dropdown');
  const dashBranchName = document.getElementById('dashboard-current-branch');

  dashBranchBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const showing = dashBranchDropdown.style.display === 'block';
    dashBranchDropdown.style.display = showing ? 'none' : 'block';
  });

  document.querySelectorAll('.dash-branch-option').forEach(opt => {
    opt.addEventListener('click', () => {
      const selected = opt.getAttribute('data-branch') || 'main';
      if (dashBranchName) dashBranchName.textContent = selected;
      if (dashBranchDropdown) dashBranchDropdown.style.display = 'none';
    });
  });

  document.addEventListener('click', () => {
    if (dashBranchDropdown) dashBranchDropdown.style.display = 'none';
  });

  // Copier & Close actions for dashboard file reader preview
  const dashCopyBtn = document.getElementById('dashboard-copy-code-btn');
  const dashCloseBtn = document.getElementById('dashboard-close-preview-btn');
  
  dashCloseBtn?.addEventListener('click', () => {
    const codePreview = document.getElementById('dashboard-code-preview');
    if (codePreview) codePreview.style.display = 'none';
  });

  dashCopyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(activeCodeText);
    dashCopyBtn.textContent = "Copied!";
    setTimeout(() => {
      dashCopyBtn.textContent = "Copy";
    }, 1500);
  });

  // ================= INTERACTIVE SYNC CONSOLE ANIMATION SCRIPT =================
  const triggerSyncBtn = document.getElementById('trigger-sync-btn');
  const overlay = document.getElementById('terminal-sync-overlay');
  const consoleBody = document.getElementById('terminal-body-console');
  const closeTermBtn = document.getElementById('close-terminal-btn');

  const logs = [
    { text: "🛰️ CONNECTING TO LOCAL FILE SYSTEM LISTENER...", delay: 400 },
    { text: "📡 HANDSHAKE SUCCESSFUL: Local Agent active.", delay: 400 },
    { text: "🔍 SCANNING PATH: c:\\Users\\ayush\\OneDrive\\Desktop\\AI ML IIT Mandi\\05_Open_Source_Repos\\", delay: 600 },
    { text: "📂 Directory detected: Models/ (linear_regression.py, README.md)", delay: 500 },
    { text: "📂 Directory detected: References/ (MATH_FOUNDATIONS.md, README.md)", delay: 500 },
    { text: "📂 Directory detected: Tools/ (setup_env.sh, README.md)", delay: 500 },
    { text: "🔄 COMPARISON PROTOCOL: Comparing local states against master commits...", delay: 800 },
    { text: "💡 STATUS: Local files match upstream repository states perfectly.", delay: 500 },
    { text: "⚡ SYNCING TELEMETRY STACK...", delay: 400 },
    { text: "📈 Updating contribution graphs...", delay: 600 },
    { text: "🟩 Contribution heatmap indices generated.", delay: 400 },
    { text: "🚀 SUCCESS: local workspace repositories successfully synchronized!", delay: 400 },
    { text: "\n" +
            "      /\\\n" +
            "     /  \\\n" +
            "    /    \\\n" +
            "   /      \\\n" +
            "  |  IIT-  |\n" +
            "  | MANDI  |\n" +
            "  |  SYNC  |\n" +
            "  |________|\n" +
            "  |   __   |\n" +
            "  |  |  |  |\n" +
            "  |__|__|__|\n" +
            "     /  \\\n" +
            "    /____\\\n" +
            "    **  **\n" +
            "   ***  ***\n" +
            "\n[Git status check: clean. Sync exit code: 0]", delay: 100 }
  ];

  triggerSyncBtn?.addEventListener('click', () => {
    if (!overlay || !consoleBody || !closeTermBtn) return;
    
    // Open Overlay
    overlay.style.display = 'flex';
    closeTermBtn.style.display = 'none';
    consoleBody.innerHTML = "";
    
    let currentLogIndex = 0;
    
    function printNextLog() {
      if (currentLogIndex >= logs.length) {
        closeTermBtn.style.display = 'block';
        return;
      }
      
      const log = logs[currentLogIndex];
      const p = document.createElement('div');
      p.style.whiteSpace = 'pre';
      
      // Formatting color
      if (log.text.startsWith("❌")) p.style.color = '#ef4444';
      else if (log.text.startsWith("🚀") || log.text.startsWith("🟩")) p.style.color = '#22c55e';
      else if (log.text.startsWith("💡")) p.style.color = '#fde047';
      else p.style.color = '#22c55e';
      
      p.textContent = log.text;
      consoleBody.appendChild(p);
      consoleBody.scrollTop = consoleBody.scrollHeight;
      
      currentLogIndex++;
      setTimeout(printNextLog, log.delay);
    }
    
    printNextLog();
  });

  closeTermBtn?.addEventListener('click', () => {
    if (overlay) overlay.style.display = 'none';
  });

  // ================= INTERACTIVE CONTRIBUTION GRAPH CLICK SCRIPT =================
  const squares = document.querySelectorAll('.contribution-square');
  const detailsToast = document.getElementById('heatmap-details-toast');

  squares.forEach(sq => {
    sq.addEventListener('click', () => {
      const commits = sq.getAttribute('data-commits');
      const week = parseInt(sq.getAttribute('data-week')) + 1;
      const day = parseInt(sq.getAttribute('data-day')) + 1;
      
      if (detailsToast) {
        detailsToast.style.display = 'block';
        let detailText = `📅 Week ${week}, Day ${day} &bull; <strong>${commits} commits</strong> detected. `;
        if (parseInt(commits) === 0) {
          detailText += "No curriculum updates recorded on this day.";
          detailsToast.style.backgroundColor = '#ef4444';
        } else {
          detailText += `Curriculum files modified: ` + (commits > 5 ? 'gradient-descent.astro, README.md, linear_regression.py' : 'BaseLayout.astro, math-foundations.md');
          detailsToast.style.backgroundColor = '#8B5CF6';
        }
        detailsToast.innerHTML = detailText;
      }
    });
  });
</script>

