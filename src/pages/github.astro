        <span>📡 LOCAL WORKSPACE GIT SYNC PROTOCOL</span>
        <button id="close-terminal-btn" class="neo-border" style="display: none; background: #ef4444; color: #fff; padding: 0.2rem 0.5rem; font-size: 0.75rem; font-weight: bold; cursor: pointer;">CLOSE</button>
      </div>
      <div id="terminal-body-console" style="padding: 1.5rem; font-family: 'Courier New', Courier, monospace; font-size: 0.85rem; color: #22c55e; max-height: 400px; overflow-y: auto; background: #000; line-height: 1.5;">
        <!-- Filled dynamically by sync process script -->
