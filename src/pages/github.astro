<script is:inline>
  // Tab Navigation switching
  const tabs = document.querySelectorAll('.nav-tab');
  const panels = document.querySelectorAll('.tab-panel-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Reset tabs
      tabs.forEach(t => {
        t.classList.remove('active');
        t.style.backgroundColor = '#fff';
      });
      // Reset panels
      panels.forEach(p => p.classList.remove('active-panel'));

      // Activate selected
      tab.classList.add('active');
      tab.style.backgroundColor = '#a8d5ff';
      
      const targetId = `tab-${tab.getAttribute('data-target')}`;
      const targetPanel = document.getElementById(targetId);
      if (targetPanel) {
        targetPanel.classList.add('active-panel');
      }
    });
  });

  // Link repo names inside Overview to switch directly to the Repositories Tab and scroll
  document.querySelectorAll('.repo-switch-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const repoName = btn.getAttribute('data-repo');
      
      // Trigger Tab Change
      const repoTab = document.querySelector('[data-target="repositories"]');
      if (repoTab) repoTab.click();

      // Trigger Foldout Expand of that repository
      setTimeout(() => {
        const foldoutBtn = document.querySelector(`.explore-local-btn[data-repo="${repoName}"]`);
        if (foldoutBtn) {
          foldoutBtn.click();
          // Scroll smoothly
          foldoutBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }, 100);
    });
  });

  // ================= REPOSITORY FILE EXPLORER FOLDOUT SCRIPT =================
  const exploreBtns = document.querySelectorAll('.explore-local-btn');
  
  exploreBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const repoName = btn.getAttribute('data-repo');
      const foldout = document.getElementById(`explorer-foldout-${repoName}`);
      
      if (foldout) {
        const showing = foldout.style.display === 'block';
        foldout.style.display = showing ? 'none' : 'block';
        btn.textContent = showing ? `📂 Explore Files` : `❌ Close Explorer`;
      }
    });
  });

  // Interactive Local File Reader
  const filesContentMap = JSON.parse(document.getElementById('serialized-files-content')?.getAttribute('data-content') || '{}');
  const fileItems = document.querySelectorAll('.explorer-file-item');

  fileItems.forEach(item => {
    item.addEventListener('click', () => {
      const repoName = item.getAttribute('data-repo');
      const fileName = item.getAttribute('data-file');
      
      // Deactivate all sibling file entries in that specific repository explore panel
      const parentExplorer = item.closest('.explorer-foldout');
      parentExplorer.querySelectorAll('.explorer-file-item').forEach(el => {
        el.style.backgroundColor = 'transparent';
        el.style.color = '#24292f';
      });

      // Highlight active clicked file
      item.style.backgroundColor = '#000';
      item.style.color = '#fff';

      // Load contents from serialized map
      const fileKey = `${repoName}/${fileName}`;
      const content = filesContentMap[fileKey] || '# No content available in this file.';
      
      // Select output areas
      const placeholder = parentExplorer.querySelector('.file-viewer-placeholder');
      const pre = parentExplorer.querySelector('.file-viewer-pre');
      const code = parentExplorer.querySelector('.file-viewer-code');

      if (placeholder && pre && code) {
        placeholder.style.display = 'none';
        pre.style.display = 'block';
        code.textContent = content;
      }
    });
  });

  // ================= INTERACTIVE SYNC CONSOLE ANIMATION SCRIPT =================
  const triggerSyncBtn = document.getElementById('trigger-sync-btn');
  const overlay = document.getElementById('terminal-sync-overlay');
  const consoleBody = document.getElementById('terminal-body-console');
  const closeTermBtn = document.getElementById('close-terminal-btn');

  const logs = [
    { text: "🛰️ CONNECTING TO LOCAL FILE SYSTEM LISTENER...", delay: 400 },
    { text: "📡 HANDSHAKE SUCCESSFUL: Local Agent active.", delay: 400 },
    { text: "🔍 SCANNING PATH: c:\\Users\\ayush\\OneDrive\\Desktop\\AI ML IIT Mandi\\05_Open_Source_Repos\\", delay: 600 },
    { text: "📂 Directory detected: Models/ (linear_regression.py, README.md)", delay: 500 },
    { text: "📂 Directory detected: References/ (MATH_FOUNDATIONS.md, README.md)", delay: 500 },
    { text: "📂 Directory detected: Tools/ (setup_env.sh, README.md)", delay: 500 },
    { text: "🔄 COMPARISON PROTOCOL: Comparing local states against master commits...", delay: 800 },
    { text: "💡 STATUS: Local files match upstream repository states perfectly.", delay: 500 },
    { text: "⚡ SYNCING TELEMETRY STACK...", delay: 400 },
    { text: "📈 Updating contribution graphs...", delay: 600 },
    { text: "🟩 Contribution heatmap indices generated.", delay: 400 },
    { text: "🚀 SUCCESS: local workspace repositories successfully synchronized!", delay: 400 },
    { text: "\n" +
            "      /\\\n" +
            "     /  \\\n" +
            "    /    \\\n" +
            "   /      \\\n" +
            "  |  IIT-  |\n" +
            "  | MANDI  |\n" +
            "  |  SYNC  |\n" +
            "  |________|\n" +
            "  |   __   |\n" +
            "  |  |  |  |\n" +
            "  |__|__|__|\n" +
            "     /  \\\n" +
            "    /____\\\n" +
            "    **  **\n" +
            "   ***  ***\n" +
            "\n[Git status check: clean. Sync exit code: 0]", delay: 100 }
  ];

  triggerSyncBtn?.addEventListener('click', () => {
    if (!overlay || !consoleBody || !closeTermBtn) return;
    
    // Open Overlay
    overlay.style.display = 'flex';
    closeTermBtn.style.display = 'none';
    consoleBody.innerHTML = "";
    
    let currentLogIndex = 0;
    
    function printNextLog() {
      if (currentLogIndex >= logs.length) {
        closeTermBtn.style.display = 'block';
        return;
      }
      
      const log = logs[currentLogIndex];
      const p = document.createElement('div');
      p.style.whiteSpace = 'pre';
      
      // Formatting color
      if (log.text.startsWith("❌")) p.style.color = '#ef4444';
      else if (log.text.startsWith("🚀") || log.text.startsWith("🟩")) p.style.color = '#22c55e';
      else if (log.text.startsWith("💡")) p.style.color = '#fde047';
      else p.style.color = '#22c55e';
      
      p.textContent = log.text;
      consoleBody.appendChild(p);
      consoleBody.scrollTop = consoleBody.scrollHeight;
      
      currentLogIndex++;
      setTimeout(printNextLog, log.delay);
    }
    
    printNextLog();
  });

  closeTermBtn?.addEventListener('click', () => {
    if (overlay) overlay.style.display = 'none';
  });

  // ================= INTERACTIVE CONTRIBUTION GRAPH CLICK SCRIPT =================
  const squares = document.querySelectorAll('.contribution-square');
  const detailsToast = document.getElementById('heatmap-details-toast');

  squares.forEach(sq => {
    sq.addEventListener('click', () => {
      const commits = sq.getAttribute('data-commits');
      const week = parseInt(sq.getAttribute('data-week')) + 1;
      const day = parseInt(sq.getAttribute('data-day')) + 1;
      
      if (detailsToast) {
        detailsToast.style.display = 'block';
        let detailText = `📅 Week ${week}, Day ${day} &bull; <strong>${commits} commits</strong> detected. `;
        if (parseInt(commits) === 0) {
          detailText += "No curriculum updates recorded on this day.";
          detailsToast.style.backgroundColor = '#ef4444';
        } else {
          detailText += `Curriculum files modified: ` + (commits > 5 ? 'gradient-descent.astro, README.md, linear_regression.py' : 'BaseLayout.astro, math-foundations.md');
          detailsToast.style.backgroundColor = '#8B5CF6';
        }
        detailsToast.innerHTML = detailText;
      }
    });
  });
</script>

