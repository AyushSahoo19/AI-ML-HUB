  <!-- Interactive Terminal Overlay Widget for Repository Sync Logs -->
  <div id="terminal-sync-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 100; align-items: center; justify-content: center; padding: 2rem;">
    <div class="neo-border" style="background: #1e1e1e; width: 100%; max-width: 700px; box-shadow: 8px 8px 0px #000; border-width: 4px; overflow: hidden;">
