  // Custom, lightweight, fast markdown to brutalist HTML parser
  function formatMarkdown(text) {
    if (!text) return "";
    
    let html = text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;");
    
    // Fenced code blocks
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (match, lang, code) => {
      return `<pre style="background-color: #1e1e1e; color: #d4d4d4; padding: 1rem; border: 3px solid #000; overflow-x: auto; font-family: monospace; margin-bottom: 1.5rem; box-shadow: 3px 3px 0px #000;"><code style="background: none; border: none; padding: 0; color: inherit;">${code}</code></pre>`;
    });
    
    // Inline code block
    html = html.replace(/`([^`]+)`/g, '<code style="background-color: #f3f4f6; padding: 0.2rem 0.4rem; border: 1px solid #000; font-family: monospace; font-size: 0.85em;">$1</code>');
    
    // Tables formatting (telemetry tables)
    const lines = html.split('\n');
    let inTable = false;
    let tableRows = [];
    let finalLines = [];
    
    for (let i = 0; i < lines.length; i++) {
      const line = lines[i].trim();
      if (line.startsWith('|') && line.endsWith('|')) {
        if (!inTable) {
          inTable = true;
          tableRows = [];
        }
        tableRows.push(line);
      } else {
        if (inTable) {
          let tableHtml = '<table style="width: 100%; border-collapse: collapse; border: 3px solid #000; margin-bottom: 1.5rem; font-size: 0.85rem; font-weight: bold; background-color: #fff; box-shadow: 4px 4px 0 #000;">';
          const filteredRows = tableRows.filter(r => !r.includes('---|') && !r.includes(':---|'));
          
          filteredRows.forEach((row, rIdx) => {
            const cells = row.split('|').slice(1, -1).map(c => c.trim());
            tableHtml += `<tr style="border-bottom: 2px solid #000; ${rIdx === 0 ? 'background-color: #fde047;' : ''}">`;
            cells.forEach(cell => {
              const tag = rIdx === 0 ? 'th' : 'td';
              tableHtml += `<${tag} style="padding: 0.6rem 1rem; border-right: 2px solid #000; text-align: left;">${cell}</${tag}>`;
            });
            tableHtml += '</tr>';
          });
          tableHtml += '</table>';
          finalLines.push(tableHtml);
          inTable = false;
        }
        finalLines.push(lines[i]);
      }
    }
    if (inTable) {
      let tableHtml = '<table style="width: 100%; border-collapse: collapse; border: 3px solid #000; margin-bottom: 1.5rem; font-size: 0.85rem; font-weight: bold; background-color: #fff; box-shadow: 4px 4px 0 #000;">';
      const filteredRows = tableRows.filter(r => !r.includes('---|') && !r.includes(':---|'));
      filteredRows.forEach((row, rIdx) => {
        const cells = row.split('|').slice(1, -1).map(c => c.trim());
        tableHtml += `<tr style="border-bottom: 2px solid #000; ${rIdx === 0 ? 'background-color: #fde047;' : ''}">`;
        cells.forEach(cell => {
          const tag = rIdx === 0 ? 'th' : 'td';
          tableHtml += `<${tag} style="padding: 0.6rem 1rem; border-right: 2px solid #000; text-align: left;">${cell}</${tag}>`;
        });
        tableHtml += '</tr>';
      });
      tableHtml += '</table>';
      finalLines.push(tableHtml);
    }
    
    html = finalLines.join('\n');

    // Headers
    html = html.replace(/^#\s+(.+)$/gm, '<h1 style="font-size: 1.6rem; font-weight: 900; border-bottom: 3px solid #000; padding-bottom: 0.5rem; margin-top: 1.5rem; margin-bottom: 1rem; text-transform: uppercase;">$1</h1>');
    html = html.replace(/^##\s+(.+)$/gm, '<h2 style="font-size: 1.25rem; font-weight: 900; border-bottom: 2px dashed #000; padding-bottom: 0.4rem; margin-top: 1.5rem; margin-bottom: 0.75rem; text-transform: uppercase;">$1</h2>');
    html = html.replace(/^###\s+(.+)$/gm, '<h3 style="font-size: 1.05rem; font-weight: 900; margin-top: 1.25rem; margin-bottom: 0.5rem; text-transform: uppercase;">$1</h3>');
    
    // Lists
    html = html.replace(/^\-\s+(.+)$/gm, '<li style="margin-bottom: 0.35rem; font-weight: bold; color: #374151;">$1</li>');
    html = html.replace(/(<li[\s\S]*?<\/li>)+/g, (match) => {
      return `<ul style="list-style-type: square; padding-left: 1.5rem; margin-bottom: 1.25rem;">${match}</ul>`;
    });
    
    // Bold
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    
    // Horizontal Rule
    html = html.replace(/^---$/gm, '<hr style="border: none; border-top: 2px dashed #000; margin: 1.5rem 0;" />');
    
    // Paragraphs
    const blockTags = ['h1', 'h2', 'h3', 'ul', 'li', 'pre', 'table', 'hr', 'div'];
    const formattedLines = html.split('\n').map(line => {
      const trimmed = line.trim();
      if (!trimmed) return "";
      
      const isBlock = blockTags.some(tag => trimmed.startsWith(`<${tag}`) || trimmed.startsWith(`</${tag}`));
      if (isBlock) return line;
      
      return `<p style="margin-bottom: 1rem; font-weight: bold; color: #374151; line-height: 1.6;">${line}</p>`;
    });
    
    return formattedLines.filter(l => l !== "").join('\n');
  }

  // Render Explorer directory tree
  function renderExplorerTable() {
    const tbody = document.getElementById('dashboard-explorer-tbody');
    const rootBreadcrumb = document.getElementById('dashboard-explorer-root');
    const activeFolderBreadcrumb = document.getElementById('dashboard-explorer-active-folder');
    const divider = document.getElementById('dashboard-explorer-divider');
    const backBtn = document.getElementById('dashboard-explorer-back-btn');
    const codePreview = document.getElementById('dashboard-code-preview');
    
    if (!tbody) return;
    tbody.innerHTML = "";
    
    if (rootBreadcrumb) rootBreadcrumb.textContent = activeRepo;
    
    if (activePath === "") {
      if (activeFolderBreadcrumb) activeFolderBreadcrumb.textContent = "";
      if (divider) divider.style.display = "none";
      if (backBtn) backBtn.style.display = "none";
    } else {
      if (activeFolderBreadcrumb) activeFolderBreadcrumb.textContent = activePath;
      if (divider) divider.style.display = "inline";
      if (backBtn) backBtn.style.display = "block";
    }

    const files = repoFilesIndex[activeRepo] || [];
    
    if (files.length === 0) {
      tbody.innerHTML = `<tr><td colspan="3" style="padding: 1rem; text-align: center; font-weight: bold; color: #6b7280;">Empty Repository</td></tr>`;
      return;
    }
    
    files.forEach(fileName => {
      const tr = document.createElement('tr');
      tr.style.borderBottom = "1px solid #e5e7eb";
      tr.style.cursor = "pointer";
      
      tr.onmouseover = () => tr.style.backgroundColor = "#f9fafb";
      tr.onmouseout = () => tr.style.backgroundColor = "transparent";
      
      let mockCommit = "Add modules implementations";
      if (fileName.includes("regression")) mockCommit = "Implement ordinary least squares regression class";
      if (fileName.includes("setup_env")) mockCommit = "Automated conda env and hardware configure script";
      if (fileName.includes("MATH_FOUNDATION")) mockCommit = "Add course linear algebra and vector formulas list";
      if (fileName.includes("README")) mockCommit = `Update comprehensive README.md for ${activeRepo} repository`;

      tr.innerHTML = `
        <td style="padding: 0.75rem 1rem; color: #000;"><span style="margin-right: 0.5rem;">📄</span>${fileName}</td>
        <td style="padding: 0.75rem 1rem; color: #57606a;">${mockCommit}</td>
        <td style="padding: 0.75rem 1rem; color: #57606a; text-align: right;">2 hours ago</td>
      `;
      
      tr.addEventListener('click', () => {
        // Open file code block preview
        const fileKey = `${activeRepo}/${fileName}`;
        const content = filesContentMap[fileKey] || '# No content available in this file.';
        
        const previewFilename = document.getElementById('dashboard-preview-filename');
        const previewCodeBlock = document.getElementById('dashboard-preview-code-block');
        
        if (codePreview && previewFilename && previewCodeBlock) {
          previewFilename.textContent = fileKey;
          previewCodeBlock.textContent = content;
          activeCodeText = content;
          codePreview.style.display = "block";
          codePreview.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      });
      
      tbody.appendChild(tr);
    });
  }

  // Open Repository detail dashboard SPA
  window.openRepositoryDashboard = function(repoName) {
    activeRepo = repoName;
    activePath = "";
    
    // Hide main profile views
    const ghSidebar = document.querySelector('.gh-sidebar');
    const ghTabsNav = document.querySelector('.gh-tabs-nav');
    const ghContentWrapper = document.querySelector('.gh-content-wrapper');
    const ghGrid = document.getElementById('github-grid');
    
    if (ghSidebar) ghSidebar.style.display = 'none';
    if (ghTabsNav) ghTabsNav.style.display = 'none';
    if (ghContentWrapper) ghContentWrapper.style.display = 'none';
    if (ghGrid) {
      ghGrid.style.display = 'block'; // Make grid take full width
    }
    
    // Show repo dashboard
    const dashboard = document.getElementById('github-repo-dashboard');
    if (dashboard) {
      dashboard.style.display = 'block';
      dashboard.scrollIntoView({ behavior: 'smooth' });
    }
    
    // Update dashboard labels
    const repoTitleEl = document.getElementById('dashboard-repo-name');
    if (repoTitleEl) repoTitleEl.textContent = repoName;
    
    const meta = reposMetaData[repoName] || {};
    
    const starsEl = document.getElementById('dashboard-stars');
    const forksEl = document.getElementById('dashboard-forks');
    if (starsEl) starsEl.textContent = meta.stars || 0;
    if (forksEl) forksEl.textContent = meta.forks || 0;
    
    const starsSidebar = document.getElementById('dashboard-stars-sidebar');
    const forksSidebar = document.getElementById('dashboard-forks-sidebar');
    if (starsSidebar) starsSidebar.textContent = `⭐ ${meta.stars || 0} Stars`;
    if (forksSidebar) forksSidebar.textContent = `🍴 ${meta.forks || 0} Forks`;
    
    const aboutEl = document.getElementById('dashboard-about-desc');
    if (aboutEl) aboutEl.textContent = meta.description || "";
    
    // Update files stats
    const filesList = repoFilesIndex[repoName] || [];
    const countBadge = document.getElementById('dashboard-files-count-badge');
    if (countBadge) countBadge.textContent = filesList.length;
    
    // Reset Code preview
    const codePreview = document.getElementById('dashboard-code-preview');
    if (codePreview) codePreview.style.display = 'none';
    
    // Render explorer table
    renderExplorerTable();
    
    // Parse and render README.md content
    const readmeKey = `${repoName}/README.md`;
    const readmeContent = filesContentMap[readmeKey] || '# README.md not found.';
    const readmeBody = document.getElementById('dashboard-readme-body');
    if (readmeBody) readmeBody.innerHTML = formatMarkdown(readmeContent);
    
    // Populate Issues
    const issuesContainer = document.getElementById('dashboard-issues-list');
    if (issuesContainer) {
      issuesContainer.innerHTML = "";
      const issues = repoIssues[repoName] || [];
      const issuesCount = document.getElementById('dashboard-issues-count');
      if (issuesCount) issuesCount.textContent = issues.length;
      
      if (issues.length === 0) {
        issuesContainer.innerHTML = `<div style="text-align: center; font-weight: bold; color: #6b7280; padding: 1.5rem;">No active issues.</div>`;
      } else {
        issues.forEach(issue => {
          const div = document.createElement('div');
          div.className = "neo-border";
          div.style.padding = "1rem";
          div.style.backgroundColor = "#fff";
          div.style.borderWidth = "2.5px";
          
          let commentsHtml = "";
          if (issue.comments) {
            commentsHtml = `
              <div style="font-size: 0.75rem; font-weight: bold; color: #9ca3af; display: flex; gap: 1rem; margin-top: 0.5rem;">
                <span>Opened ${issue.time} by 👤 ${issue.author}</span>
                <span style="color: #0969da; cursor: pointer;" class="comment-trigger-btn" data-issue-id="${issue.id}">💬 ${issue.comments.length} Comments</span>
              </div>
              <div id="dash-comments-issue-${issue.id}" style="display: none; border-top: 2px dashed #000; margin-top: 0.75rem; padding-top: 0.75rem; font-size: 0.8rem; display: flex; flex-direction: column; gap: 0.5rem;">
                ${issue.comments.map(c => `
                  <div style="background-color: #fafafa; padding: 0.5rem; border-left: 3px solid #000;">
                    <strong>👤 ${c.author}:</strong> ${c.text}
                  </div>
                `).join('')}
              </div>
            `;
          } else {
            commentsHtml = `
              <div style="font-size: 0.75rem; font-weight: bold; color: #9ca3af; display: flex; gap: 1rem; margin-top: 0.5rem;">
                <span>Opened ${issue.time} by 👤 ${issue.author}</span>
              </div>
            `;
          }
          
          div.innerHTML = `
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem;">
              <h3 style="font-size: 1.1rem; font-weight: bold; margin: 0; color: #000;">
