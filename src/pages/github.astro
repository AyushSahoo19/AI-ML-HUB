---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// Dynamically read files inside 05_Open_Source_Repos
const reposPath = path.resolve('..', '05_Open_Source_Repos');

let modelsFiles = [];
let referencesFiles = [];
let toolsFiles = [];

try {
  modelsFiles = fs.readdirSync(path.join(reposPath, 'Models')).filter(f => f !== '.DS_Store');
} catch (e) {
  modelsFiles = ['README.md', 'linear_regression.py'];
}

try {
  referencesFiles = fs.readdirSync(path.join(reposPath, 'References')).filter(f => f !== '.DS_Store');
} catch (e) {
  referencesFiles = ['README.md', 'MATH_FOUNDATIONS.md'];
}

try {
  toolsFiles = fs.readdirSync(path.join(reposPath, 'Tools')).filter(f => f !== '.DS_Store');
} catch (e) {
  toolsFiles = ['README.md', 'setup_env.sh'];
}

// Fetch file contents to serialize for live file viewer
const filesContent = {};

const reposData = [
  { name: 'Models', files: modelsFiles },
  { name: 'References', files: referencesFiles },
  { name: 'Tools', files: toolsFiles }
];

reposData.forEach(repo => {
  repo.files.forEach(file => {
    const filePath = path.join(reposPath, repo.name, file);
    try {
      filesContent[`${repo.name}/${file}`] = fs.readFileSync(filePath, 'utf-8');
    } catch (e) {
      filesContent[`${repo.name}/${file}`] = "# Error loading local file content.";
    }
  });
});

const repositories = [
  {
    name: 'Models',
    description: 'Curated repository containing high-performance models and custom implementations of classical ML and Deep Learning algorithms.',
    language: 'Python',
    langColor: '#3572A5',
    stars: 48,
    forks: 14,
    files: modelsFiles,
    localPath: '05_Open_Source_Repos/Models/'
  },
  {
    name: 'References',
    description: 'Comprehensive documentation, reference textbook materials, formulas, and course curriculum guides.',
    language: 'Markdown',
    langColor: '#083344',
    stars: 12,
    forks: 2,
    files: referencesFiles,
    localPath: '05_Open_Source_Repos/References/'
  },
  {
    name: 'Tools',
    description: 'Development environment setup scripts, packages installs trackers, and automated validation code tools.',
    language: 'Shell',
    langColor: '#89e051',
    stars: 8,
    forks: 1,
    files: toolsFiles,
    localPath: '05_Open_Source_Repos/Tools/'
  }
];

// Generate dynamic contribution heatmap data (365 days)
const contributionWeeks = 53;
const daysOfWeek = 7;
const contributionsMap = [];
const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

// Seed random commits
let seed = 12345;
function random() {
  let x = Math.sin(seed++) * 10000;
  return x - Math.floor(x);
}

for (let w = 0; w < contributionWeeks; w++) {
  const weekData = [];
  for (let d = 0; d < daysOfWeek; d++) {
    const val = random();
    let commits = 0;
    if (val > 0.85) commits = Math.floor(random() * 8) + 4;
    else if (val > 0.6) commits = Math.floor(random() * 4) + 1;
    
    let color = "#ebedf0"; // no commits
    if (commits > 0 && commits <= 2) color = "#c6e48b";
    else if (commits > 2 && commits <= 5) color = "#7bc96f";
    else if (commits > 5) color = "#239a3b";
    
    const tooltip = `${commits} commits on Week ${w + 1}, Day ${d + 1}`;
    
    weekData.push({
      commits,
      color,
      tooltip
    });
  }
  contributionsMap.push(weekData);
}
