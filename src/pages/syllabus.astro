---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeoCard from '../components/NeoCard.astro';
---

<BaseLayout title="Curriculum Syllabus - AI/ML Hub">
  <div style="max-width: 900px; margin: 0 auto;">
    <header style="margin-bottom: 2rem;">
      <h1 class="responsive-title" style="font-weight: 900; text-transform: uppercase; margin-bottom: 0.25rem; text-align: center;">Master Syllabus</h1>
      <p style="text-align: center; font-size: 1rem; font-weight: bold; color: #4b5563;">From Basic Mathematics to Advanced MLOps (2024-2025)</p>
    </header>

    <div style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- Phase 1 -->
      <section class="syllabus-section" style="border-bottom: 2px solid #a8d5ff; padding-bottom: 1.5rem;">
        <div class="sticky-header">
          <h2 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0;">Phase 1: Foundations</h2>
          <div style="width: 40px; height: 6px; background-color: #a8d5ff; border: 1px solid #000;"></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <NeoCard color="#a8d5ff" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Programming</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>Python Syntax & OOP</li>
              <li>Data Structures</li>
              <li>NumPy & Matrix Math</li>
              <li>Pandas & Data</li>
            </ul>
          </NeoCard>
          <NeoCard color="#a8d5ff" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Mathematics</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>Linear Algebra</li>
              <li>Calculus & Gradients</li>
              <li>Probability</li>
              <li>Descriptive Stats</li>
            </ul>
          </NeoCard>
        </div>
      </section>

      <!-- Phase 2 -->
      <section class="syllabus-section" style="border-bottom: 2px solid #bbf7d0; padding-bottom: 1.5rem;">
        <div class="sticky-header">
          <h2 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0;">Phase 2: Machine Learning</h2>
          <div style="width: 40px; height: 6px; background-color: #bbf7d0; border: 1px solid #000;"></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <NeoCard color="#bbf7d0" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Supervised</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>Linear/Logistic Reg</li>
              <li>SVMs & Trees</li>
              <li>Random Forests</li>
              <li>XGBoost</li>
            </ul>
          </NeoCard>
          <NeoCard color="#bbf7d0" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Unsupervised</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>K-Means Clustering</li>
              <li>PCA Reduction</li>
              <li>Bias/Variance</li>
              <li>Cross-Validation</li>
            </ul>
          </NeoCard>
        </div>
      </section>

      <!-- Phase 3 -->
      <section class="syllabus-section" style="border-bottom: 2px solid #e9d5ff; padding-bottom: 1.5rem;">
        <div class="sticky-header">
          <h2 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0;">Phase 3: Deep Learning</h2>
          <div style="width: 40px; height: 6px; background-color: #e9d5ff; border: 1px solid #000;"></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <NeoCard color="#e9d5ff" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Core Concepts</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>Perceptrons</li>
              <li>Backpropagation</li>
              <li>Optimizers (Adam)</li>
              <li>PyTorch/TF</li>
            </ul>
          </NeoCard>
          <NeoCard color="#e9d5ff" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Architectures</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>CNNs (Vision)</li>
              <li>RNNs & LSTMs</li>
              <li>Time-series</li>
            </ul>
          </NeoCard>
        </div>
      </section>

      <!-- Phase 4 -->
      <section class="syllabus-section" style="border-bottom: 2px solid #fef08a; padding-bottom: 1.5rem;">
        <div class="sticky-header">
          <h2 style="font-size: 1.1rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0;">Phase 4: GenAI & MLOps</h2>
          <div style="width: 40px; height: 6px; background-color: #fef08a; border: 1px solid #000;"></div>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <NeoCard color="#fef08a" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">Generative AI</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>Transformers</li>
              <li>LLMs</li>
              <li>RAG Architecture</li>
              <li>Fine-tuning (LoRA)</li>
            </ul>
          </NeoCard>
          <NeoCard color="#fef08a" class="p-4" style="padding: 1rem;">
            <h3 style="font-weight: 900; font-size: 0.95rem; margin-bottom: 0.5rem;">MLOps</h3>
            <ul style="line-height: 1.4; padding-left: 1rem; font-size: 0.85rem; font-weight: bold; margin: 0;">
              <li>MLflow Tracking</li>
              <li>Vector Databases</li>
              <li>Model Serving</li>
              <li>Docker</li>
            </ul>
          </NeoCard>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .syllabus-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .sticky-header {
    position: static;
  }
  @media (min-width: 768px) {
    .syllabus-section {
      grid-template-columns: 1fr 3fr;
    }
    .sticky-header {
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
