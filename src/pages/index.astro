---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeoCard from '../components/NeoCard.astro';
import GitHubRepoCard from '../components/GitHubRepoCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const lectures = await getCollection('lectures');
const latestLectures = lectures.sort((a, b) => b.data.day - a.data.day).slice(0, 3);
---

<BaseLayout title="AI & ML IIT Mandi">
  <!-- 1. Massive Branded Hero Section -->
  <section class="hero neo-border neo-shadow" style="padding: 3rem 1.5rem; margin-bottom: 4rem; background-color: #a8d5ff; text-align: center; border-width: 4px;">
    <h1 class="responsive-title" style="font-weight: 900; text-transform: uppercase; margin-bottom: 1rem; letter-spacing: -1px; color: #000; line-height: 1;">The Ultimate AI Brain</h1>
    <p style="font-size: 1.25rem; font-weight: bold; max-width: 700px; margin: 0 auto 2.5rem; line-height: 1.5; color: #1f2937;">
      From basic linear algebra to deploying massive Generative AI models. This is a fully open-source, brutalist learning ecosystem designed to track progress and consolidate knowledge.
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/domains/mathematics" class="neo-border bg-yellow neo-hover-raise" style="padding: 0.5rem 1rem; font-weight: 900; font-size: 0.9rem; text-decoration: none; color: #000; box-shadow: 2px 2px 0px #000; display: inline-block;"># Mathematics &rarr;</a>
      <a href="/domains/machine-learning" class="neo-border bg-green neo-hover-raise" style="padding: 0.5rem 1rem; font-weight: 900; font-size: 0.9rem; text-decoration: none; color: #000; background-color: #bbf7d0; box-shadow: 2px 2px 0px #000; display: inline-block;"># Machine Learning &rarr;</a>
      <a href="/domains/deep-learning" class="neo-border bg-violet neo-hover-raise" style="padding: 0.5rem 1rem; font-weight: 900; font-size: 0.9rem; text-decoration: none; color: #000; background-color: #e9d5ff; box-shadow: 2px 2px 0px #000; display: inline-block;"># Deep Learning &rarr;</a>
      <a href="/domains/generative-ai" class="neo-border bg-yellow neo-hover-raise" style="padding: 0.5rem 1rem; font-weight: 900; font-size: 0.9rem; text-decoration: none; color: #000; background-color: #fef08a; box-shadow: 2px 2px 0px #000; display: inline-block;"># Generative AI &rarr;</a>
    </div>
  </section>

  <!-- 2. How to Use / Guidance Index -->
  <section id="guidance" style="margin-bottom: 4rem;">
    <h2 style="font-size: 2rem; font-weight: 900; text-transform: uppercase; margin-bottom: 1.5rem; border-bottom: 4px solid #000; padding-bottom: 0.5rem;">How to Use This Hub</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; align-items: stretch;">
      <a href="/how-to-use/learn" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
        <NeoCard color="#fef08a" class="neo-hover-raise" style="border-width: 3px; height: 100%; display: flex; flex-direction: column; flex-grow: 1;">
          <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 0.5rem;">01. Learn &rarr;</h3>
          <p style="font-weight: bold; font-size: 0.9rem; color: #374151; line-height: 1.4; margin: 0; flex-grow: 1;">Follow the chronological syllabus. Read the detailed notes, study the diagrams, and master the theory step-by-step.</p>
        </NeoCard>
      </a>
      <a href="/how-to-use/code" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
        <NeoCard color="#e9d5ff" class="neo-hover-raise" style="border-width: 3px; height: 100%; display: flex; flex-direction: column; flex-grow: 1;">
          <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 0.5rem;">02. Code &rarr;</h3>
          <p style="font-weight: bold; font-size: 0.9rem; color: #374151; line-height: 1.4; margin: 0; flex-grow: 1;">Copy the embedded Python snippets into your local Jupyter Notebooks and run the models to truly understand the math.</p>
        </NeoCard>
      </a>
      <a href="/how-to-use/build" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
        <NeoCard color="#a8d5ff" class="neo-hover-raise" style="border-width: 3px; height: 100%; display: flex; flex-direction: column; flex-grow: 1;">
          <h3 style="font-size: 1.5rem; font-weight: 900; margin-bottom: 0.5rem;">03. Build &rarr;</h3>
          <p style="font-weight: bold; font-size: 0.9rem; color: #374151; line-height: 1.4; margin: 0; flex-grow: 1;">Check the Projects Lab to see how theory is applied to real-world, open-source repositories.</p>
        </NeoCard>
      </a>
    </div>
  </section>

  <!-- 3. Curriculum Overview -->
  <section id="curriculum" style="margin-bottom: 4rem; padding: 2rem; background-color: #000; color: #fff;" class="neo-border neo-shadow">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; border-bottom: 2px dashed #fff; padding-bottom: 1rem; gap: 1rem; flex-wrap: wrap;">
      <h2 style="font-size: 2rem; font-weight: 900; text-transform: uppercase; margin: 0;">Curriculum Index</h2>
      <a href="/syllabus" style="color: #fef08a; font-weight: bold; text-decoration: none; font-size: 1rem;">View Master Syllabus &rarr;</a>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
      <div>
        <h3 style="color: #a8d5ff; font-weight: 900; font-size: 1.2rem; margin-bottom: 0.5rem;">Phase 1: Foundations</h3>
        <ul style="list-style-type: square; padding-left: 1.5rem; font-size: 0.9rem; line-height: 1.6; font-weight: bold;">
          <li>Linear Algebra & Calculus</li>
          <li>Probability & Stats</li>
          <li>Python (NumPy, Pandas)</li>
        </ul>
      </div>
      <div>
        <h3 style="color: #bbf7d0; font-weight: 900; font-size: 1.2rem; margin-bottom: 0.5rem;">Phase 2: Machine Learning</h3>
        <ul style="list-style-type: square; padding-left: 1.5rem; font-size: 0.9rem; line-height: 1.6; font-weight: bold;">
          <li>Supervised Learning (RF, SVM)</li>
          <li>Unsupervised (K-Means, PCA)</li>
          <li>Scikit-Learn</li>
        </ul>
      </div>
      <div>
        <h3 style="color: #e9d5ff; font-weight: 900; font-size: 1.2rem; margin-bottom: 0.5rem;">Phase 3: Deep Learning</h3>
        <ul style="list-style-type: square; padding-left: 1.5rem; font-size: 0.9rem; line-height: 1.6; font-weight: bold;">
          <li>Neural Networks (CNNs, RNNs)</li>
          <li>Backpropagation</li>
          <li>PyTorch / TensorFlow</li>
        </ul>
      </div>
      <div>
        <h3 style="color: #fef08a; font-weight: 900; font-size: 1.2rem; margin-bottom: 0.5rem;">Phase 4: GenAI & MLOps</h3>
        <ul style="list-style-type: square; padding-left: 1.5rem; font-size: 0.9rem; line-height: 1.6; font-weight: bold;">
          <li>Transformers & LLMs</li>
          <li>RAG Architecture</li>
          <li>Deployment (MLflow, Docker)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 4. Dynamic Dashboard Grid Section -->
  <div class="responsive-grid-1-2" style="margin-bottom: 4rem; gap: 3rem;">
    
    <!-- LEFT COLUMN: Lectures & Projects Overview -->
    <div style="display: flex; flex-direction: column; gap: 3.5rem;">
      
      <!-- A. Lecture Vault Preview -->
      <section id="notes">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1.5rem; border-bottom: 3.5px solid #000; padding-bottom: 0.5rem; gap: 1rem; flex-wrap: wrap;">
          <h2 style="font-size: 1.75rem; font-weight: 900; text-transform: uppercase; margin: 0;">Recent Lectures</h2>
          <a href="/lectures" style="font-weight: 900; font-size: 0.9rem; color: #0969da; text-decoration: none;">View Full Vault &rarr;</a>
        </div>
        
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {latestLectures.map((lecture) => {
            let accentColor = '#a8d5ff';
            const mod = lecture.data.module || '';
            if (mod.includes('Machine')) accentColor = '#bbf7d0';
            if (mod.includes('Deep')) accentColor = '#e9d5ff';
            if (mod.includes('GenAI')) accentColor = '#fef08a';

            return (
              <a href={`/lectures/${lecture.id}`} class="neo-border neo-hover-raise" style={`text-decoration: none; color: inherit; padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; border-width: 3px; background-color: ${accentColor}; box-shadow: 4px 4px 0px #000; flex-wrap: wrap; gap: 1rem;`}>
                <div>
                  <p style="font-size: 0.7rem; font-weight: 900; color: #374151; text-transform: uppercase; margin: 0 0 0.25rem 0;">Day {lecture.data.day} &bull; {lecture.data.date}</p>
                  <h3 style="font-size: 1.15rem; font-weight: 900; margin: 0; color: #000;">{lecture.data.title}</h3>
                </div>
                <span style="font-size: 0.75rem; font-weight: 900; border: 2px solid #000; padding: 0.2rem 0.5rem; background: #fff; text-transform: uppercase; border-radius: 0;">
                  {lecture.data.module?.split(':')[1] || lecture.data.module}
                </span>
              </a>
            );
          })}
        </div>
      </section>

      <!-- B. Projects Lab Preview -->
      <section id="projects">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1.5rem; border-bottom: 3.5px solid #000; padding-bottom: 0.5rem; gap: 1rem; flex-wrap: wrap;">
          <h2 style="font-size: 1.75rem; font-weight: 900; text-transform: uppercase; margin: 0;">Projects Lab</h2>
          <a href="/projects" style="font-weight: 900; font-size: 0.9rem; color: #0969da; text-decoration: none;">View Portfolio &rarr;</a>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
          {projects.slice(0, 2).map((project) => (
            <GitHubRepoCard 
              title={project.data.title} 
              description={project.data.description} 
              language={project.data.language} 
              stars={project.data.stars} 
              url={`/projects/${project.id}`}
            />
          ))}
        </div>
      </section>

    </div>

    <!-- RIGHT COLUMN: Interactive Experiments Spotlight -->
    <div>
      <section id="experiments" style="position: sticky; top: 1.5rem;">
        <div style="border-bottom: 3.5px solid #000; padding-bottom: 0.5rem; margin-bottom: 1.5rem;">
          <h2 style="font-size: 1.75rem; font-weight: 900; text-transform: uppercase; margin: 0;">Experiments Lab</h2>
        </div>

        <div class="neo-border neo-shadow" style="background-color: #fff; padding: 1.5rem; border-width: 3.5px;">
          <!-- Experiment Badge -->
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <span style="font-size: 2rem;">📈</span>
            <span style="font-size: 0.7rem; font-weight: 900; border: 2px solid #000; padding: 0.15rem 0.5rem; background-color: #bbf7d0; text-transform: uppercase; border-radius: 0;">Live Simulator</span>
          </div>

          <h3 style="font-size: 1.35rem; font-weight: 900; text-transform: uppercase; margin: 0 0 0.5rem 0; color: #000;">
            Gradient Descent Convergence
          </h3>
          <p style="font-size: 0.9rem; font-weight: bold; color: #4b5563; line-height: 1.5; margin: 0 0 1.5rem 0;">
            Experience mathematical landscapes in real-time. Adjust learning rates, select loss surfaces, and click to plot starting parameter paths to watch convergence boundaries update instantly!
          </p>

          <a href="/experiments/gradient-descent" class="neo-border neo-hover-raise" style="display: block; text-align: center; text-decoration: none; font-weight: 900; background-color: #fca5a5; color: #000; padding: 0.75rem; border-width: 3px; box-shadow: 4px 4px 0px #000; margin-bottom: 1.25rem;">
            Launch Gradient Visualizer &rarr;
          </a>

          <a href="/experiments" style="display: block; text-align: center; font-weight: bold; font-size: 0.85rem; color: #4b5563; text-decoration: underline;">
            Explore other experiments in the lab
          </a>
        </div>
      </section>
    </div>

  </div>
</BaseLayout>
